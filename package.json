{
  "name": "neurolife",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:lan": "bash scripts/dev-lan.sh",
    "dev:tmux": "bash scripts/dev-tmux.sh",
    "stop:dev": "bash scripts/stop-dev.sh",
    "health": "bash scripts/health.sh",
    "verify:dev": "bash scripts/verify-dev.sh",
    "build": "turbo run build",
    "test": "pnpm --filter @neurolife/api test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @neurolife/database generate",
    "db:migrate": "pnpm --filter @neurolife/database migrate",
    "db:push": "pnpm --filter @neurolife/database push",
    "db:seed": "pnpm --filter @neurolife/database seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
