# Database
DATABASE_URL="postgresql://neurolife:neurolife@localhost:5432/neurolife?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO / S3
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="neurolife"
S3_SECRET_KEY="neurolifesecret"
S3_BUCKET="neurolife-docs"
S3_REGION="us-east-1"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption
ENCRYPTION_MASTER_KEY="change-me-32-byte-key-here!!!!"

# AI (optional, cloud-assisted mode)
OPENAI_API_KEY=""
SELF_HOSTED_AI_URL=""

# API
API_PORT=3001
API_HOST="0.0.0.0"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# LAN dev (pnpm dev:lan sets these automatically from hostname -I)
# DEV_LAN_IP="192.168.12.127"
# CORS_ORIGIN="http://localhost:3000,http://192.168.12.127:3000"
