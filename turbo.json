{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "API_HOST",
    "CORS_ORIGIN",
    "DEV_LAN_IP",
    "NEXT_PUBLIC_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
